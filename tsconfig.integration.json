{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out-integration",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node", "mocha"]
  },
  "include": ["test-integration", "src/shared.ts", "src/opencode/protocol.ts"],
  "exclude": ["node_modules", "dist", "out", "out-test"]
}
